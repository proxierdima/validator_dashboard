new file mode 100644
index 0000000..8c76090
--- /dev/null
+++ b/app/collectors/governance_collector.py
@@ -0,0 +1,228 @@
+from __future__ import annotations
+
+import asyncio
+from datetime import datetime, timezone
+from typing import Any
+
+import httpx
+from sqlalchemy import select
+
+from app.core.db import SessionLocal
+from app.models import CollectorRun, GovernanceProposal, Network, NetworkEndpoint, Validator
+
+TIMEOUT = httpx.Timeout(connect=4.0, read=15.0, write=10.0, pool=10.0)
+
+V1_PATH = "/cosmos/gov/v1/proposals?pagination.limit=100&proposal_status=PROPOSAL_STATUS_VOTING_PERIOD"
+V1BETA1_PATH = "/cosmos/gov/v1beta1/proposals?pagination.limit=100&proposal_status=2"
+
+
+def normalize_base_url(url: str) -> str:
+    return (url or "").rstrip("/")
+
+
+async def fetch_json(client: httpx.AsyncClient, url: str) -> dict[str, Any] | None:
+    try:
+        response = await client.get(url)
+        if response.status_code != 200:
+            return None
+        return response.json()
+    except Exception:
+        return None
+
+
+def parse_proposals(payload: dict[str, Any] | None) -> list[dict[str, Any]]:
+    if not payload:
+        return []
+    proposals = payload.get("proposals") or []
+    if isinstance(proposals, list):
+        return proposals
+    return []
+
+
+def extract_title(proposal: dict[str, Any]) -> str | None:
+    metadata = proposal.get("metadata")
+    if isinstance(metadata, str) and metadata.strip():
+        return metadata[:4000]
+    content = proposal.get("content") or {}
+    title = content.get("title") or proposal.get("title")
+    if title is not None:
+        return str(title)[:4000]
+    messages = proposal.get("messages") or []
+    if messages:
+        return str(messages[0].get("@type") or "proposal")[:4000]
+    return None
+
+
+def extract_description(proposal: dict[str, Any]) -> str | None:
+    content = proposal.get("content") or {}
+    description = content.get("description") or proposal.get("summary")
+    if description is None:
+        return None
+    return str(description)[:5000]
+
+
+def extract_status(proposal: dict[str, Any]) -> str | None:
+    status = proposal.get("status") or proposal.get("proposal_status")
+    if status is None:
+        return None
+    return str(status)[:64]
+
+
+def extract_proposal_id(proposal: dict[str, Any]) -> int | None:
+    value = proposal.get("id") or proposal.get("proposal_id")
+    try:
+        return int(value)
+    except Exception:
+        return None
+
+
+async def collect_for_network(
+    client: httpx.AsyncClient,
+    network_id: int,
+    rest_urls: list[str],
+    validator_voter_address: str | None,
+) -> tuple[int, list[dict[str, Any]]]:
+    proposals: list[dict[str, Any]] = []
+    for rest_url in rest_urls:
+        payload = await fetch_json(client, normalize_base_url(rest_url) + V1_PATH)
+        proposals = parse_proposals(payload)
+        if proposals:
+            break
+        payload = await fetch_json(client, normalize_base_url(rest_url) + V1BETA1_PATH)
+        proposals = parse_proposals(payload)
+        if proposals:
+            break
+    return network_id, [
+        {
+            "proposal_id": extract_proposal_id(item),
+            "title": extract_title(item),
+            "description": extract_description(item),
+            "status": extract_status(item),
+            "voting_start_time": str(item.get("voting_start_time") or "")[:32] or None,
+            "voting_end_time": str(item.get("voting_end_time") or "")[:32] or None,
+            "validator_voter_address": validator_voter_address,
+            "validator_voted": 0,
+            "validator_vote_option": None,
+        }
+        for item in proposals
+        if extract_proposal_id(item) is not None
+    ]
+
+
+async def run_async(network_jobs: list[tuple[int, list[str], str | None]]) -> dict[int, list[dict[str, Any]]]:
+    async with httpx.AsyncClient(timeout=TIMEOUT, follow_redirects=True) as client:
+        results = await asyncio.gather(
+            *[
+                collect_for_network(client, network_id, rest_urls, validator_voter_address)
+                for network_id, rest_urls, validator_voter_address in network_jobs
+            ]
+        )
+    return {network_id: proposals for network_id, proposals in results}
+
+
+def main() -> None:
+    db = SessionLocal()
+    started = datetime.now(timezone.utc)
+    run = CollectorRun(
+        collector_name="governance_collector",
+        status="running",
+        started_at=started,
+        items_processed=0,
+    )
+    db.add(run)
+    db.commit()
+    db.refresh(run)
+
+    try:
+        networks = db.execute(
+            select(Network).where(Network.is_enabled == 1).order_by(Network.name.asc())
+        ).scalars().all()
+        network_ids = [network.id for network in networks]
+        if not network_ids:
+            run.status = "success"
+            run.finished_at = datetime.now(timezone.utc)
+            run.duration_ms = int((run.finished_at - started).total_seconds() * 1000)
+            db.commit()
+            return
+
+        rest_rows = db.execute(
+            select(NetworkEndpoint.network_id, NetworkEndpoint.url)
+            .where(NetworkEndpoint.network_id.in_(network_ids))
+            .where(NetworkEndpoint.is_enabled == 1)
+            .where(NetworkEndpoint.endpoint_type == "rest")
+            .order_by(NetworkEndpoint.network_id.asc(), NetworkEndpoint.priority.asc(), NetworkEndpoint.id.asc())
+        ).all()
+        rest_map: dict[int, list[str]] = {}
+        for network_id, url in rest_rows:
+            rest_map.setdefault(network_id, []).append(url)
+
+        validator_rows = db.execute(
+            select(Validator.network_id, Validator.delegator_address)
+            .where(Validator.network_id.in_(network_ids))
+            .where(Validator.is_enabled == 1)
+            .where(Validator.is_main == 1)
+        ).all()
+        validator_map = {network_id: delegator_address for network_id, delegator_address in validator_rows}
+
+        jobs = [
+            (network.id, rest_map.get(network.id, []), validator_map.get(network.id))
+            for network in networks
+            if rest_map.get(network.id)
+        ]
+        collected = asyncio.run(run_async(jobs)) if jobs else {}
+
+        snapshot_at = datetime.now(timezone.utc).isoformat()
+        total_items = 0
+        for network in networks:
+            db.query(GovernanceProposal).filter(
+                GovernanceProposal.network_id == network.id,
+                GovernanceProposal.is_latest == 1,
+            ).update({"is_latest": 0}, synchronize_session=False)
+
+            for proposal in collected.get(network.id, []):
+                db.add(
+                    GovernanceProposal(
+                        network_id=network.id,
+                        proposal_id=proposal["proposal_id"],
+                        title=proposal["title"],
+                        description=proposal["description"],
+                        status=proposal["status"],
+                        voting_start_time=proposal["voting_start_time"],
+                        voting_end_time=proposal["voting_end_time"],
+                        yes_votes=None,
+                        no_votes=None,
+                        abstain_votes=None,
+                        no_with_veto_votes=None,
+                        validator_voter_address=proposal["validator_voter_address"],
+                        validator_voted=proposal["validator_voted"],
+                        validator_vote_option=proposal["validator_vote_option"],
+                        snapshot_at=snapshot_at,
+                        last_updated_at=snapshot_at,
+                        is_latest=1,
+                    )
+                )
+                total_items += 1
+
+        finished = datetime.now(timezone.utc)
+        run.status = "success"
+        run.finished_at = finished
+        run.duration_ms = int((finished - started).total_seconds() * 1000)
+        run.items_processed = total_items
+        db.commit()
+        print(f"Governance collector complete: {total_items} proposals")
+    except Exception as exc:
+        db.rollback()
+        finished = datetime.now(timezone.utc)
+        run.status = "failed"
+        run.finished_at = finished
+        run.duration_ms = int((finished - started).total_seconds() * 1000)
+        run.error_message = str(exc)[:2000]
+        db.add(run)
+        db.commit()
+        raise
+    finally:
+        db.close()
+
+
+if __name__ == "__main__":
+    main()
diff --git a/app/collectors/reward_status_collector.py b/app/collectors/reward_status_collector.py
new file mode 100644
index 0000000..97ac672
--- /dev/null
+++ b/app/collectors/reward_status_collector.py
@@ -0,0 +1,182 @@
+from __future__ import annotations
+
+import json
+import os
+from datetime import datetime, timedelta, timezone
+from pathlib import Path
+
+from sqlalchemy import select
+
+from app.core.db import SessionLocal
+from app.models import CollectorRun, Event, Network
+
+DATA_FILE = Path(os.getenv("COMMISSION_SNAPSHOT_PATH", "commission_snapshot.json"))
+MAX_AGE_HOURS = int(os.getenv("REWARD_SNAPSHOT_MAX_AGE_HOURS", "24"))
+
+
+def normalize(value: str | None) -> str:
+    return (value or "").strip().lower()
+
+
+def open_or_update_event(db, network_id: int, severity: str, title: str, message: str, now: datetime) -> None:
+    event_key = f"reward_status:{network_id}"
+    existing = db.execute(
+        select(Event)
+        .where(Event.event_key == event_key)
+        .where(Event.status == "open")
+        .limit(1)
+    ).scalar_one_or_none()
+    if existing is None:
+        db.add(
+            Event(
+                network_id=network_id,
+                validator_id=None,
+                event_type="reward_status",
+                severity=severity,
+                title=title,
+                message=message,
+                event_key=event_key,
+                status="open",
+                first_seen_at=now,
+                last_seen_at=now,
+                resolved_at=None,
+                metadata_json=None,
+            )
+        )
+        return
+
+    existing.severity = severity
+    existing.title = title
+    existing.message = message
+    existing.last_seen_at = now
+    existing.resolved_at = None
+
+
+def resolve_event(db, network_id: int, now: datetime) -> None:
+    event_key = f"reward_status:{network_id}"
+    existing = db.execute(
+        select(Event)
+        .where(Event.event_key == event_key)
+        .where(Event.status == "open")
+        .limit(1)
+    ).scalar_one_or_none()
+    if existing is None:
+        return
+    existing.status = "resolved"
+    existing.last_seen_at = now
+    existing.resolved_at = now
+
+
+def build_snapshot_lookup(data: dict) -> dict[str, dict]:
+    rows = data.get("rows") or []
+    totals_by_network = data.get("totals_by_network") or {}
+    lookup: dict[str, dict] = {}
+    for name, total in totals_by_network.items():
+        lookup[normalize(name)] = {"total": total}
+    for row in rows:
+        network_name = row.get("network") or row.get("chain") or row.get("name")
+        if network_name:
+            key = normalize(str(network_name))
+            entry = lookup.setdefault(key, {})
+            entry.setdefault("rows", []).append(row)
+    return lookup
+
+
+def main() -> None:
+    db = SessionLocal()
+    started = datetime.now(timezone.utc)
+    run = CollectorRun(
+        collector_name="reward_status_collector",
+        status="running",
+        started_at=started,
+        items_processed=0,
+    )
+    db.add(run)
+    db.commit()
+    db.refresh(run)
+
+    try:
+        networks = db.execute(
+            select(Network).where(Network.is_enabled == 1).order_by(Network.name.asc())
+        ).scalars().all()
+        now = datetime.now(timezone.utc)
+
+        if not DATA_FILE.exists():
+            for network in networks:
+                open_or_update_event(
+                    db,
+                    network.id,
+                    "critical",
+                    "Rewards snapshot missing",
+                    f"Expected rewards snapshot file not found: {DATA_FILE}",
+                    now,
+                )
+            run.status = "success"
+            run.finished_at = now
+            run.duration_ms = int((now - started).total_seconds() * 1000)
+            run.items_processed = len(networks)
+            db.commit()
+            print("Reward status collector complete: snapshot missing")
+            return
+
+        mtime = datetime.fromtimestamp(DATA_FILE.stat().st_mtime, tz=timezone.utc)
+        snapshot_age = now - mtime
+        is_stale = snapshot_age > timedelta(hours=MAX_AGE_HOURS)
+
+        data = json.loads(DATA_FILE.read_text(encoding="utf-8"))
+        lookup = build_snapshot_lookup(data)
+
+        processed = 0
+        for network in networks:
+            aliases = {
+                normalize(network.name),
+                normalize(network.display_name),
+                normalize(network.directory),
+                normalize(network.chain_id),
+            }
+            matched = next((lookup[key] for key in aliases if key and key in lookup), None)
+
+            if is_stale:
+                open_or_update_event(
+                    db,
+                    network.id,
+                    "warning",
+                    "Rewards snapshot is stale",
+                    f"Rewards snapshot age is {int(snapshot_age.total_seconds())} seconds, exceeding {MAX_AGE_HOURS} hours.",
+                    now,
+                )
+            elif matched is None:
+                open_or_update_event(
+                    db,
+                    network.id,
+                    "warning",
+                    "Network missing in rewards snapshot",
+                    f"Network '{network.name}' was not found in {DATA_FILE.name}.",
+                    now,
+                )
+            else:
+                resolve_event(db, network.id, now)
+            processed += 1
+
+        run.status = "success"
+        run.finished_at = now
+        run.duration_ms = int((now - started).total_seconds() * 1000)
+        run.items_processed = processed
+        db.commit()
+        print(f"Reward status collector complete: {processed} networks")
+    except Exception as exc:
+        db.rollback()
+        finished = datetime.now(timezone.utc)
+        run.status = "failed"
+        run.finished_at = finished
+        run.duration_ms = int((finished - started).total_seconds() * 1000)
+        run.error_message = str(exc)[:2000]
+        db.add(run)
+        db.commit()
+        raise
+    finally:
+        db.close()
+
+
+if __name__ == "__main__":
+    main()
