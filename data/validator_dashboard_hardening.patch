+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+
+from app.core.db import SessionLocal
+from app.models import CollectorRun, Event, Network, Validator
+
+
+def main() -> None:
+    db = SessionLocal()
+    run = CollectorRun(
+        collector_name="reward_status_collector",
+        status="running",
+        started_at=datetime.now(timezone.utc),
+    )
+    db.add(run)
+    db.commit()
+
+    processed = 0
+    try:
+        now = datetime.now(timezone.utc)
+        stale_after = now - timedelta(days=2)
+
+        networks = db.query(Network).filter(Network.is_enabled == 1).all()
+        for network in networks:
+            validator = (
+                db.query(Validator)
+                .filter(Validator.network_id == network.id)
+                .filter(Validator.is_enabled == 1)
+                .filter(Validator.is_main == 1)
+                .first()
+            )
+            if validator is None:
+                continue
+
+            existing = (
+                db.query(Event)
+                .filter(Event.network_id == network.id)
+                .filter(Event.event_type == "reward_pipeline")
+                .filter(Event.event_key == f"reward_pipeline:{network.id}")
+                .filter(Event.status == "open")
+                .first()
+            )
+
+            if validator.updated_at is None or validator.updated_at < stale_after:
+                if existing is None:
+                    db.add(
+                        Event(
+                            network_id=network.id,
+                            validator_id=validator.id,
+                            event_type="reward_pipeline",
+                            severity="warning",
+                            title=f"Reward pipeline has no recent data for {network.name}",
+                            message="Rewards collector is not yet integrated into the bootstrap pipeline.",
+                            event_key=f"reward_pipeline:{network.id}",
+                            status="open",
+                            first_seen_at=now,
+                            last_seen_at=now,
+                            metadata_json='{"source": "reward_status_collector"}',
+                        )
+                    )
+                else:
+                    existing.last_seen_at = now
+                processed += 1
+            elif existing is not None:
+                existing.status = "resolved"
+                existing.resolved_at = now
+                existing.last_seen_at = now
+
+        run.status = "success"
+        run.items_processed = processed
+        run.finished_at = datetime.now(timezone.utc)
+        db.commit()
+        print(f"reward_status_collector completed: {processed} events updated")
+    except Exception as exc:
+        run.status = "failed"
+        run.error_message = str(exc)
+        run.finished_at = datetime.now(timezone.utc)
+        db.commit()
+        raise
+    finally:
+        db.close()
+
+
+if __name__ == "__main__":
+    main()
