+def _pick_rest_url(db, network_id: int) -> str | None:
+    endpoint = (
+        db.query(NetworkEndpoint)
+        .filter(NetworkEndpoint.network_id == network_id)
+        .filter(NetworkEndpoint.endpoint_type == "rest")
+        .filter(NetworkEndpoint.is_enabled == 1)
+        .order_by(NetworkEndpoint.is_public.desc(), NetworkEndpoint.priority.asc())
+        .first()
+    )
+    return endpoint.url.rstrip("/") if endpoint else None
+
+
+def _pick_validator_voter(db, network_id: int) -> str | None:
+    validator = (
+        db.query(Validator)
+        .filter(Validator.network_id == network_id)
+        .filter(Validator.is_enabled == 1)
+        .filter(Validator.is_main == 1)
+        .first()
+    )
+    return validator.delegator_address if validator else None
+
+
+def _fetch_proposals(rest_url: str) -> list[dict]:
+    url = f"{rest_url}/cosmos/gov/v1/proposals"
+    resp = requests.get(url, timeout=REQUEST_TIMEOUT)
+    resp.raise_for_status()
+    data = resp.json()
+    return data.get("proposals", [])
+
+
+def main() -> None:
+    db = SessionLocal()
+    run = CollectorRun(
+        collector_name="governance_collector",
+        status="running",
+        started_at=datetime.now(timezone.utc),
+    )
+    db.add(run)
+    db.commit()
+
+    processed = 0
+
+    try:
+        networks = (
+            db.query(Network)
+            .filter(Network.is_enabled == 1)
+            .order_by(Network.name.asc())
+            .all()
+        )
+
+        snapshot_at = datetime.now(timezone.utc).isoformat()
+
+        for network in networks:
+            rest_url = _pick_rest_url(db, network.id)
+            if not rest_url:
+                continue
+
+            voter = _pick_validator_voter(db, network.id)
+
+            try:
+                proposals = _fetch_proposals(rest_url)
+            except Exception as exc:
+                print(f"[WARN] governance fetch failed for {network.name}: {exc}")
+                continue
+
+            db.execute(
+                update(GovernanceProposal)
+                .where(GovernanceProposal.network_id == network.id)
+                .values(is_latest=0)
+            )
+
+            for proposal in proposals:
+                status = proposal.get("status")
+                if status not in ACTIVE_PROPOSAL_STATUSES:
+                    continue
+
+                final_tally = proposal.get("final_tally_result") or {}
+
+                row = GovernanceProposal(
+                    network_id=network.id,
+                    proposal_id=int(proposal.get("id", 0)),
+                    title=(proposal.get("title") or proposal.get("metadata") or "")[:1000] or None,
+                    description=(proposal.get("summary") or "")[:4000] or None,
+                    status=status,
+                    voting_start_time=proposal.get("voting_start_time"),
+                    voting_end_time=proposal.get("voting_end_time"),
+                    yes_votes=final_tally.get("yes_count"),
+                    no_votes=final_tally.get("no_count"),
